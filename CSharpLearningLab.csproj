<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Trimming Roslyn is too aggressive — it strips compiler internals we need at runtime. -->
    <PublishTrimmed>false</PublishTrimmed>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.0" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Scripting" Version="5.3.0" />
    <!-- Ships every .NET reference DLL as an embedded byte array so Roslyn can compile against
         the full BCL from inside the browser, where we can't load assemblies from disk. -->
    <PackageReference Include="Basic.Reference.Assemblies.Net90" Version="1.8.3" />
  </ItemGroup>

</Project>
